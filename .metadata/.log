			} else if(numLog[i + 1] - numLog[i] == -10) {
				answer + an
			}
			
		}
		return answer;
	}
	
	public static void main(String[] args) {
//		String str = "wsdawsdassw";
//		System.out.println(str.length());
		String str = "wsdawsdassw";
		int len = str.length();
		int[] arrBasket = new int[len];
		int currentValue = 0;
		for(int i = 0; i < arrBasket.length; i++) {
			char c = str.charAt(i);
			if(c == 'w') {
				currentValue = currentValue + 1;
			} else if(c == 's') {
				currentValue = currentValue - 1;
			} else if(c == 'd') {
				currentValue = currentValue + 10;
			} else if(c == 'a') {
				currentValue = currentValue - 10;
			}
			arrBasket[i] = currentValue;
		}
		solution(arrBasket);
		// wsdawsdassw
	}
}

